{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"linter": {
		"rules": {
			"style": {
				"useTemplate": "off"
			},
			"nursery": {
				"noFloatingPromises": "error"
			}
		}
	},
	"formatter": {
		"lineWidth": 100
	}
}